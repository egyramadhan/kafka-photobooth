# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to git (already in .gitignore)

# ============================================
# Phase 2 — Cloudinary (QR Share & Upload)
# ============================================
# Get these from: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_API_SECRET=
VITE_CLOUDINARY_UPLOAD_PRESET=

# ============================================
# Phase 3 — PostgreSQL Database (Local)
# ============================================
# Your local PostgreSQL connection details
VITE_DB_HOST=localhost
VITE_DB_PORT=5432
VITE_DB_NAME=photobooth
VITE_DB_USER=postgres
VITE_DB_PASSWORD=

# ============================================
# Phase 3 — Dashboard Protection
# ============================================
# Simple password for /dashboard access
VITE_DASHBOARD_PASSWORD=

# ============================================
# Notes:
# ============================================
# - All variables must start with VITE_ to be exposed to client
# - Never commit .env.local to git
# - Restart dev server after changing env variables
